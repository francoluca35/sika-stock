{
	"buildCommand": "bash scripts/vercel-build.sh",
	"outputDirectory": "build/web",
	"rewrites": [
		{
			"source": "/:path((?!.*\\.).*)",
			"destination": "/index.html"
		}
	],
	"headers": [
		{
			"source": "/manifest.json",
			"headers": [
				{
					"key": "Content-Type",
					"value": "application/manifest+json"
				},
				{
					"key": "Cache-Control",
					"value": "public, max-age=0, must-revalidate"
				}
			]
		}
	]
}
