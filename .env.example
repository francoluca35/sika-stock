# Copiar este archivo como ".env" en la raíz del proyecto (no commitear .env).
#
# SUPABASE_URL: Project Settings → Data API → URL (sin barra final).
#
# SUPABASE_ANON_KEY: en Settings → API Keys usá la clave anon JWT legacy (empieza con eyJ…),
# pestaña "Legacy anon / service_role keys". Las claves sb_publishable_… pueden dar errores
# raros en Edge Functions hasta desplegar las funciones con --no-verify-jwt; para Flutter + invoke
# de funciones suele ser más simple usar la anon JWT.

SUPABASE_URL=https://TU_REF.supabase.co
SUPABASE_ANON_KEY=TU_ANON_JWT_LEGACY
